{
  "name": "workflow-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/prepare-dev.mjs && next dev --webpack",
    "dev:clean": "node scripts/prepare-dev.mjs --clean && next dev --webpack",
    "dev:turbo": "node scripts/prepare-dev.mjs --turbo && next dev",
    "preview": "npm run build && npm run start",
    "build": "next build --webpack",
    "vercel-build": "prisma migrate deploy && prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && prisma generate && tsx prisma/seed.ts",
    "db:setup:local": "prisma db push && prisma generate && tsx prisma/seed.ts",
    "setup:production": "node scripts/setup-production.mjs",
    "configure:production": "node scripts/configure-vercel-production.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
